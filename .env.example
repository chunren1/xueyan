# ==================== 学研在线 — 环境变量模板 ====================
# 复制此文件为 .env，按本地环境修改后 source 或填入 IDE 运行配置

# Nacos
NACOS_HOST=127.0.0.1
NACOS_PORT=8848
NACOS_NAMESPACE=public

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=your_password_here

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=

# RabbitMQ
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Seata
SEATA_HOST=127.0.0.1
SEATA_PORT=8091

# 服务端口（可选覆盖）
# GATEWAY_SERVER_PORT=8080
# USER_SERVER_PORT=8101
# COURSE_SERVER_PORT=8102
# ORDER_SERVER_PORT=8103
# PAYMENT_SERVER_PORT=8104
